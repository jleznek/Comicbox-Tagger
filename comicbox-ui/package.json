{
  "name": "comicbox-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:exe": "powershell -ExecutionPolicy Bypass -File ./scripts/build-standalone.ps1",
    "build:installer": "powershell -ExecutionPolicy Bypass -File ./scripts/build-installer.ps1",
    "comicbox": "powershell -ExecutionPolicy Bypass -File ./scripts/run-comicbox.ps1",
    "dev": "vite",
    "dev:ui": "vite",
    "dev:api": ".\\.venv\\Scripts\\python -m uvicorn app:app --reload --app-dir backend",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.1.0"
  }
}
